generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

// ---------------------------------------------------------
// User & Auth Models
// ---------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     Address[]
  reviews       Review[]
  notificationSettings NotificationSettings?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model OTP {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}



model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  label     String   @default("Home")
  fullName  String   @default("")
  phone     String   @default("")
  
  street    String
  city      String
  state     String
  pincode   String
  country   String   @default("India")
  isDefault Boolean  @default(false)
}

// ---------------------------------------------------------
// E-Commerce Models
// ---------------------------------------------------------
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  price       Float
  salePrice   Float?
  stock       Int       @default(0)
  isFeatured  Boolean   @default(false)
  
  // Plant specific data
  careLevel   String @default("EASY")
  lightReq    String  @default("MEDIUM")
  waterReq    String?
  petFriendly Boolean   @default(false)
  airPurifier Boolean   @default(false)
  
  images      String // JSON string array of image URLs
  potColorImages String? // JSON string: { Green: string, Blue: string, White: string, Yellow: string }
  faqs        String? // JSON string array of { question, answer }
  categories  Category[]
  reviews     Review[]
  orderItems  OrderItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}



// ---------------------------------------------------------
// Order & Payment Models
// ---------------------------------------------------------
model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        String @default("PENDING")
  totalAmount   Float
  
  // Razorpay fields
  paymentId     String?
  orderId       String?     @unique
  signature     String?
  
  // Creator program fields
  isCreatorOrder Boolean   @default(false)
  couponCode     String?
  
  items         OrderItem[]
  shippingAddr  String      // Stored snapshot of address
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}



model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Stored price at time of purchase
  potColor  String? // Color of the pot selected
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// Notifications Models
// ---------------------------------------------------------
model NotificationSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  emailEnabled    Boolean @default(true)
  smsEnabled      Boolean @default(true)
  whatsappEnabled Boolean @default(false)
  pushEnabled     Boolean @default(false)
  
  fcmToken        String? // For Push Notifications
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'EMAIL', 'SMS', 'WHATSAPP', 'PUSH'
  subject   String
  status    String   // 'SENT', 'FAILED'
  createdAt DateTime @default(now())
}

model ChatLead {
  id        String   @id @default(cuid())
  name      String?
  phone     String?
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// Admin Settings Models
// ---------------------------------------------------------
model SiteSettings {
  id              String  @id @default("global")
  
  // General
  storeName       String  @default("IndoorPlant.in")
  supportEmail    String  @default("support@indoorplant.in")
  
  // AI Advisor
  aiEnabled       Boolean @default(true)
  aiTemperature   Float   @default(0.7)
  aiPromptContext String?
}

// ---------------------------------------------------------
// Creator Program Models
// ---------------------------------------------------------
model CreatorApplication {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  instagram     String
  facebook      String?
  note          String?
  
  productId     String
  productName   String   // Snapshot of product name at time of application
  productImage  String?  // Snapshot of product image
  
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  coupon        Coupon?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Coupon {
  id                   String   @id @default(cuid())
  code                 String   @unique
  discountPercent      Int      @default(100) // 100% for creator coupons
  
  productId            String   // Only valid for this specific product
  
  creatorApplicationId String   @unique
  creatorApplication   CreatorApplication @relation(fields: [creatorApplicationId], references: [id], onDelete: Cascade)
  
  isUsed               Boolean  @default(false)
  usedAt               DateTime?
  
  createdAt            DateTime @default(now())
}

// ---------------------------------------------------------
// SEO & GEO Automation Models
// ---------------------------------------------------------

/// City hub pages: /plants/{city}
/// Invisible to site visitors; discovered by Google via sitemap only.
model CityHub {
  id             String   @id @default(cuid())
  slug           String   @unique         // "bengaluru"
  cityName       String                   // "Bengaluru"
  state          String                   // "Karnataka"
  stateSlug      String                   // "karnataka"

  // SEO content — must be unique per city (not templated)
  metaTitle      String?
  metaDesc       String?
  h1             String?
  introPara      String?  @db.Text        // 150–200 words unique intro
  climateNote    String?  @db.Text        // local climate / care tip
  deliveryInfo   String?  @db.Text        // e.g. "Delivered in 2-4 days across Bengaluru"
  coverageAreas  String?                  // JSON: ["Whitefield","HSR Layout","Koramangala"]
  localReviews   String?  @db.Text        // JSON: [{name,rating,comment,area}]
  nearbyCities   String?                  // JSON: ["pune","chennai"]

  isActive       Boolean  @default(true)
  isIndexed      Boolean  @default(false) // true = explicitly approved for indexing
  batchNumber    Int      @default(1)     // 1 = Batch 1 (launch-ready), 2 = Batch 2, etc.

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// State hub pages: /plants/{state}
/// Off by default; enable only after Search Console confirms state-level demand.
model StateHub {
  id           String   @id @default(cuid())
  slug         String   @unique     // "karnataka"
  stateName    String               // "Karnataka"
  metaTitle    String?
  metaDesc     String?
  introPara    String?  @db.Text
  citySlugs    String               // JSON: ["bengaluru"]

  isActive     Boolean  @default(false) // stays OFF until demand confirmed
  isIndexed    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Product × City intersection pages: /shop/{product}/{city}
/// Auto-seeded when a product is saved; content editable in Admin > SEO.
model ProductCityPage {
  id             String   @id @default(cuid())
  productSlug    String                        // "money-plant"
  citySlug       String                        // "bengaluru"

  // Auto-generated from template; editable in admin after first seed
  metaTitle      String?
  metaDesc       String?
  h1             String?
  localCareTip   String?  @db.Text             // city-specific care note
  deliveryNote   String?                       // "Usually delivered in 2-3 days in Bengaluru"
  localPrice     Float?                        // optional city-specific price override

  isAutoGenerated Boolean @default(true)       // flipped to false once admin edits it
  isActive        Boolean @default(true)
  isIndexed       Boolean @default(false)      // true = explicitly approved for indexing

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productSlug, citySlug])
}

// -----------------------------------------------------------------------------
// BLOG & CARE CONTENT ENGINE
// -----------------------------------------------------------------------------

model Article {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String?
  content         String   @db.Text
  image           String?
  readTime        String?  // e.g. "9 min read"
  featured        Boolean  @default(false)
  
  metaTitle       String?
  metaDescription String?
  keywords        String?  // JSON array stored as string, e.g. '["plants", "care"]'
  faqSchema       String?  @db.Text // JSON for FAQ structured data
  
  // Relations
  categoryId      String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
  authorId        String?
  author          Author?   @relation(fields: [authorId], references: [id])

  isActive        Boolean  @default(true)
  isIndexed       Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogCategory {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  
  articles    Article[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Author {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  role        String?
  avatar      String?
  bio         String?
  
  articles    Article[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
